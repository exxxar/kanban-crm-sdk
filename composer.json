{
    "name": "exxxar/kanban-laravel",
    "description": "Laravel SDK for Kanban CRM Board API",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Exxxar\\Kanban\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Exxxar\\Kanban\\KanbanServiceProvider"
            ],
            "aliases": {
                "Kanban": "KanbanTaskTypeEnum"
            }
        }
    },
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    }
}
